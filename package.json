{
  "name": "@rbxts/falldown",
  "version": "1.1.7",
  "description": "A realistic ragdoll physics system for Roblox with smooth getup animations, collision management, and customizable velocity modes. Supports both R6 and R15 rigs with surface-aware positioning.",
  "main": "out/init.luau",
  "scripts": {
    "build": "rbxtsc",
    "build:test": "rbxtsc --rojo test.project.json --type game",
    "watch": "rbxtsc -w",
    "prepublishOnly": "npm run build",
    "rojo:build": "rojo build test.project.json -o testPlace.rbxlx",
    "rojo:serve": "rojo serve test.project.json"
  },
  "keywords": [
    "roblox",
    "roblox-ts",
    "rbxts",
    "ragdoll",
    "physics",
    "animation",
    "character",
    "r6",
    "r15",
    "constraints",
    "humanoid",
    "getup",
    "knockback",
    "velocity"
  ],
  "author": "irishfix",
  "license": "MIT",
  "types": "out/index.d.ts",
  "files": [
    "out/index.d.ts",
    "out/init.luau"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@rbxts/compiler-types": "^3.0.0-types.0",
    "@rbxts/types": "^1.0.867",
    "roblox-ts": "^3.0.0",
    "typedoc": "^0.28.15",
    "typedoc-material-theme": "^1.4.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@rbxts/beacon": "^2.1.1",
    "@rbxts/services": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IrishFix/rbxts-falldown.git"
  },
  "bugs": {
    "url": "https://github.com/IrishFix/rbxts-falldown/issues"
  },
  "homepage": "https://irishfix.github.io/rbxts-falldown/"
}
